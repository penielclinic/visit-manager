{
  "name": "visit-manager",
  "version": "0.1.0",
  "private": true,
  "description": "대심방 매니저 - 가구 단위 대심방 일정·동선·기록 통합 관리 시스템 (이음 플랫폼 모듈)",
  "author": "해운대순복음교회 AI위원회",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:status": "npx supabase status",
    "db:push": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "db:diff": "npx supabase db diff",
    "db:types": "npx supabase gen types typescript --linked > src/types/database.types.ts",
    "db:link": "npx supabase link",
    "db:seed": "npx supabase db reset --linked",
    "migration:new": "npx supabase migration new",
    "migration:list": "npx supabase migration list",
    "migration:repair": "npx supabase migration repair",
    "shadcn:add": "npx shadcn@latest add",
    "test": "echo \"테스트 미구현 (S8에서 추가 예정)\" && exit 0",
    "test:e2e": "echo \"E2E 테스트 미구현\" && exit 0",
    "deploy:preview": "vercel",
    "deploy:prod": "vercel --prod",
    "clean": "rm -rf .next node_modules .turbo",
    "fresh": "npm run clean && npm install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.45.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.460.0",
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.18",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
