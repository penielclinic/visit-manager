# =============================================================================
# 대심방 매니저 - .gitignore
# Next.js 14 + Supabase + macOS/Windows 표준
# =============================================================================


# -----------------------------------------------------------------------------
# 의존성 (npm/yarn/pnpm)
# -----------------------------------------------------------------------------
node_modules/
.pnp/
.pnp.js
.yarn/install-state.gz


# -----------------------------------------------------------------------------
# Next.js 빌드 산출물
# -----------------------------------------------------------------------------
.next/
out/
build/
dist/

# Next.js 캐시
.swc/

# Vercel 배포 메타
.vercel/


# -----------------------------------------------------------------------------
# 환경변수 (절대 커밋 금지!)
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# .env.example만 커밋 (템플릿)
!.env.example


# -----------------------------------------------------------------------------
# Supabase 로컬 작업 파일
# -----------------------------------------------------------------------------
supabase/.branches/
supabase/.temp/
supabase/.env
.supabase/

# 마이그레이션은 커밋 (versioned)
# supabase/migrations/  ← 커밋 대상


# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts


# -----------------------------------------------------------------------------
# 테스트 커버리지
# -----------------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/


# -----------------------------------------------------------------------------
# 로그
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log


# -----------------------------------------------------------------------------
# 에디터 / IDE
# -----------------------------------------------------------------------------
# VS Code (사용자 설정만 무시, 워크스페이스 권장 설정은 커밋)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains
.idea/
*.iml
*.iws

# Sublime
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~


# -----------------------------------------------------------------------------
# 운영체제
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*


# -----------------------------------------------------------------------------
# 임시 파일
# -----------------------------------------------------------------------------
*.tmp
*.bak
*.backup
*.cache
.cache/
.tmp/


# -----------------------------------------------------------------------------
# 본 프로젝트 전용
# -----------------------------------------------------------------------------
# 녹음 파일 로컬 캐시 (테스트용)
recordings-local/
*.webm
*.m4a
*.mp3

# 엑셀 업로드 임시 파일
uploads-temp/
*.xlsx.tmp

# 가구 데이터 백업 (개인정보 포함, 절대 커밋 금지!)
backups/
*.backup.json
households-export-*.json
members-export-*.json

# Claude Code 세션 핸드오프 (개발 중에만 사용)
handoff_*.md
session-notes-*.md

# 개인 메모
NOTES.md
TODO.md
SCRATCH.md


# -----------------------------------------------------------------------------
# 보안 관련 (절대 커밋 금지)
# -----------------------------------------------------------------------------
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
secrets/
private/


# -----------------------------------------------------------------------------
# 패키지 매니저 lock 파일은 커밋 (의존성 일관성)
# -----------------------------------------------------------------------------
# package-lock.json  ← 커밋 대상 (npm 사용 시)
# yarn.lock          ← 커밋 대상 (yarn 사용 시)
# pnpm-lock.yaml     ← 커밋 대상 (pnpm 사용 시)
