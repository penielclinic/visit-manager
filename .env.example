# =============================================================================
# 대심방 매니저 - 환경변수 템플릿
# =============================================================================
# 사용법: 이 파일을 .env.local로 복사한 후 실제 값을 채우세요
#   cp .env.example .env.local
#
# ⚠️ .env.local 파일은 절대 Git에 커밋하지 마세요 (.gitignore 등록됨)
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase (필수)
# -----------------------------------------------------------------------------
# 발급 위치: Supabase Dashboard → Project Settings → API
# - URL: 프로젝트 고유 URL
# - ANON_KEY: 클라이언트에서 사용 (public, 안전)
# - SERVICE_ROLE_KEY: 서버 사이드 전용 (절대 클라이언트 노출 금지!)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# -----------------------------------------------------------------------------
# Kakao Maps & Local API (필수)
# -----------------------------------------------------------------------------
# 발급 위치: Kakao Developers (https://developers.kakao.com)
# → 내 애플리케이션 → 앱 키
# - JavaScript 키: 클라이언트 지도 표시용
# - REST API 키: 서버 사이드 지오코딩용

NEXT_PUBLIC_KAKAO_MAP_KEY=YOUR_KAKAO_JAVASCRIPT_KEY
KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY


# -----------------------------------------------------------------------------
# Anthropic Claude API (필수)
# -----------------------------------------------------------------------------
# 발급 위치: https://console.anthropic.com/settings/keys
# 용도: 심방 녹취 텍스트를 4분류(요약/기도제목/특이/후속)로 자동 분류
# 모델: claude-sonnet-4-7

ANTHROPIC_API_KEY=sk-ant-api03-...


# -----------------------------------------------------------------------------
# OpenAI Whisper API (선택, Phase 2)
# -----------------------------------------------------------------------------
# 용도: Web Speech API 미지원 브라우저(Firefox 등)의 fallback STT
# 발급 위치: https://platform.openai.com/api-keys
# MVP에서는 비워두어도 됨

OPENAI_API_KEY=sk-...


# -----------------------------------------------------------------------------
# 교회 정보 (필수)
# -----------------------------------------------------------------------------
# 지도 동선 계산 시 출발지로 사용
# 좌표는 Kakao Maps에서 마우스 우클릭 → 이 위치 좌표 보기로 확인

NEXT_PUBLIC_CHURCH_NAME=해운대순복음교회
NEXT_PUBLIC_CHURCH_ADDRESS=부산광역시 해운대구 ...
NEXT_PUBLIC_CHURCH_LAT=35.1631
NEXT_PUBLIC_CHURCH_LNG=129.1635


# -----------------------------------------------------------------------------
# 앱 설정 (선택)
# -----------------------------------------------------------------------------

# 앱 URL (Vercel 배포 후 production URL로 교체)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 개발 환경 표시 (development | preview | production)
NEXT_PUBLIC_APP_ENV=development

# 녹음 파일 자동 삭제 일수 (기본 90일)
RECORDING_RETENTION_DAYS=90


# -----------------------------------------------------------------------------
# NHN Cloud 알림톡 (선택, 추후)
# -----------------------------------------------------------------------------
# 용도: 심방 1시간/1일 전 카카오 알림톡 발송
# MVP에서는 브라우저 알림(Notification API)만 사용

NHN_CLOUD_APP_KEY=
NHN_CLOUD_SECRET_KEY=
NHN_CLOUD_SENDER_KEY=
NHN_CLOUD_TEMPLATE_CODE=


# =============================================================================
# 환경변수 작성 후 다음 명령어로 검증
# =============================================================================
# npm run dev          # 개발 서버 실행 (오류 시 누락된 변수 표시)
# npx supabase status  # Supabase 연결 확인
# =============================================================================
